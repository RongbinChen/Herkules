# Copy this file to .env and fill in real values. .env is gitignored — never commit secrets.

# Database
DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/calendar_db

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=30d
PORT=3001

# Chinabidding scraper credentials
# Consumed by docker-compose (variable substitution) and by the backend at runtime.
CHINABIDDING_BASE_URL=https://www.chinabidding.com/en
CHINABIDDING_CAS_LOGIN_URL=https://cas.ebnew.com/cas/login
CHINABIDDING_USERNAME=your-chinabidding-username
CHINABIDDING_PASSWORD=your-chinabidding-password

# DeepSeek API — used by backend/src/services/deepseek.js for relevance filtering
# and structured extraction of tender notices. Without it, analysis is skipped.
DEEPSEEK_API_KEY=your-deepseek-api-key

# SMTP (company mailbox) — bid-watch email notifications (services/mailer.js).
# Leave unset to disable email; in-app notifications still work.
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=noreply@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM="Herkules CRM <noreply@example.com>"
