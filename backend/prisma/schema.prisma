generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                Int      @id @default(autoincrement())
  email             String   @unique
  password          String
  name              String
  isAdmin           Boolean  @default(false)
  calendarFeedToken String?  @unique
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  events            Event[]
  createdTrips      Trip[]   @relation("TripCreator")
  assignedTrips     Trip[]   @relation("TripAssignee")
}

model Event {
  id          Int              @id @default(autoincrement())
  title       String
  description String?
  start       DateTime
  end         DateTime
  allDay      Boolean          @default(false)
  color       String           @default("#2563eb")
  location    String?
  category    ActivityCategory @default(WORK_SESSION)
  status      ActivityStatus   @default(PLANNED)
  priority    ActivityPriority @default(MEDIUM)
  userId      Int
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  customerId  Int?
  customer    Customer?        @relation(fields: [customerId], references: [id], onDelete: SetNull)
  agentId     Int?
  agent       Agent?           @relation(fields: [agentId], references: [id], onDelete: SetNull)
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Customer {
  id           Int            @id @default(autoincrement())
  name         String
  address      String?
  contactName  String?
  contactPhone String?
  email        String?
  contacts     Json?          // 多联系人 [{name, phone, title, email}]；上面的 contactName/Phone/email 为主联系人（第一个）
  notes        String?
  latitude     Float?
  longitude    Float?
  status       CustomerStatus @default(LEAD) // 潜在 / 合作中 / 暂停 / 流失
  tier         CustomerTier   @default(C)    // A=战略 / B=重点 / C=普通
  tags         String[]                       // 自由标签（行业、来源等）
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  events       Event[]
  tripStops    TripStop[]

  @@index([status])
  @@index([tier])
}

// 客户共享：把筛选出的一批客户打包成免登录分享链接，推荐给同事查看
model CustomerShare {
  id          Int      @id @default(autoincrement())
  token       String   @unique // 公开分享令牌（免登录访问）
  title       String?
  customerIds Int[] // 分享包含的客户 id 列表
  createdAt   DateTime @default(now())

  @@index([token])
}

// 行程：给某位同事安排的一次出差/拜访，含多个客户站点，可生成公开分享链接
model Trip {
  id          Int        @id @default(autoincrement())
  title            String
  notes            String?
  startTime        DateTime
  endTime          DateTime
  hidePhoneOnShare Boolean    @default(false) // 公开分享页是否隐藏联系电话
  shareToken       String     @unique // 公开分享令牌（免登录访问）
  flights          Json?      // 可选航班：[{date, flightNo, routing, time, notes}]
  constraints      String?    // 规划约束/偏好（自由文本，喂给模型）
  itinerary        Json?      // 模型生成：{ days:[{date,day,location,program,logistics}], notes:[...] }
  itineraryModel   String?    // 生成所用模型
  itineraryAt      DateTime?  // 生成时间
  createdById Int
  createdBy   User       @relation("TripCreator", fields: [createdById], references: [id], onDelete: Cascade)
  assigneeId  Int?
  assignee    User?      @relation("TripAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  stops       TripStop[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([shareToken])
}

// 行程站点：行程中的一个客户拜访点，按 order 排序（最近邻路线优化后的顺序）
model TripStop {
  id              Int       @id @default(autoincrement())
  tripId          Int
  trip            Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  customerId      Int
  customer        Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  order           Int       @default(0) // 拜访顺序（0-based）
  plannedArrival  DateTime? // 建议到访时间（按起止时间均分）
  priority        String?   @default("NORMAL") // PRIORITY / NORMAL / BACKUP
  visitDuration   String?   // 拜访时长提示，如 "half day" / "1 day" / "1-1.5 days"
  notes           String?

  @@index([tripId])
}

// 代理商 / 中间商（与终端客户区分），可关联到活动
model Agent {
  id           Int      @id @default(autoincrement())
  name         String
  company      String?
  contactPhone String?
  email        String?
  region       String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  events       Event[]
}

model BidProject {
  id          Int       @id @default(autoincrement())
  projectName String
  projectCode String?   @unique
  region      String?
  industry    String?
  biddingType BidType   @default(NEW)
  publishDate DateTime?
  deadline    DateTime?
  budget      String?
  status      BidStatus @default(PUBLISHED)
  sourceUrl        String    @unique
  rawContent       String?
  summary          String?
  lastStatusChange DateTime?
  bidStage         BidStage? // 生命周期阶段（由 infoClass 派生：招标→变更→评标→中标）
  // ── Structured fields (DeepSeek extraction) ──
  purchaser     String? // 采购单位
  winner        String? // 中标方（中标公告）
  winningPrice  String? // 中标价
  equipmentType String? // 设备类型标签（轧辊磨床/龙门铣/加工中心…）
  infoClass     String? // 公告类型：New Tenders / Tender Changes / Evaluation Results / Tender Awards
  threadKey     String? // 项目线索键（Bidding NO，归并同一项目的多条公告）
  competitorId  Int? // 中标方匹配到的竞争对手
  competitor    Competitor?     @relation(fields: [competitorId], references: [id])
  follows       ProjectFollow[]
  notifications Notification[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([threadKey])
  @@index([publishDate])
}

// 被追踪公司档案：本集团 / 竞争对手 / 关注公司
model Competitor {
  id        Int          @id @default(autoincrement())
  name      String       @unique
  aliases   String[] // 名称别名（中英文、缩写）用于中标方匹配
  country   String?
  notes     String?
  watchType WatchType    @default(COMPETITOR) // OWN=本集团 / COMPETITOR=竞品 / INTEREST=关注公司
  createdAt DateTime     @default(now())
  projects  BidProject[]
}

// 用户关注的项目
model ProjectFollow {
  id        Int        @id @default(autoincrement())
  userId    Int
  projectId Int
  note      String?
  createdAt DateTime   @default(now())
  project   BidProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
}

// 站内通知
model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int
  type      NotificationType
  projectId Int?
  message   String
  readAt    DateTime?
  createdAt DateTime         @default(now())
  project   BidProject?      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
}

model ScrapeJob {
  id            Int             @id @default(autoincrement())
  type          BidType         @default(NEW)
  status        ScrapeJobStatus @default(RUNNING)
  itemsFound    Int             @default(0)
  itemsSaved    Int             @default(0)
  error         String?
  triggeredBy   Int?
  startedAt     DateTime        @default(now())
  finishedAt    DateTime?
  savedSearchId Int?
}

model SavedSearch {
  id             Int       @id @default(autoincrement())
  userId         Int
  name           String
  keyword        String
  tradeClassCode String?
  infoClassCode  String    @default("e0905")
  autoMonitor    Boolean   @default(false)
  emailNotify    Boolean   @default(false) // 发现新公告时给订阅人发邮件
  lastRunAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// 开标记录：人工上传 Excel，DeepSeek 识别结构化字段后入库
model BidOpening {
  id           Int       @id @default(autoincrement())
  biddingNo    String?   // 招标编号（识别）
  projectName  String?
  openDate     DateTime? // 开标日期（识别）
  purchaser    String?   // 采购/招标单位（识别）
  bidders      Json?     // 投标人清单 [{name, price, note}]
  summary      String?   // 一句话摘要（识别）
  rawText      String?   // 从 Excel 提取的原始文本（备查）
  fileName     String?
  shareToken   String?   @unique // 公开分享令牌（免登录查看）
  translations Json?     // 语言翻译缓存，如 { en: { projectName, purchaser, bidders:[{country,...}] } }
  uploadedById Int?
  createdAt    DateTime  @default(now())

  @@index([biddingNo])
}

enum ActivityCategory {
  WORK_SESSION
  MEETING
  SALES_MEETING
  FIELD_WORK
  BREAK
  TRAINING
  LEAVE
}

enum ActivityStatus {
  PLANNED
  IN_PROGRESS
  DONE
  BLOCKED
}

enum ActivityPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum BidStatus {
  PUBLISHED
  CLOSED
  CANCELLED
  UNKNOWN
}

enum BidType {
  NEW
  PAST
}

// 公告推导的项目生命周期阶段（自动，来自抓取的 infoClass）
enum BidStage {
  TENDER     // 招标公告 New Tenders
  CHANGE     // 变更公告 Tenders Changes
  EVALUATION // 评标结果 Evaluation Results
  AWARD      // 中标公告 Tender Awards
}

// 我方投标跟踪状态（手工，销售团队视角）
enum OurBidStatus {
  WATCHING    // 关注中
  PREPARING   // 准备投标
  SUBMITTED   // 已投标
  SHORTLISTED // 入围
  WON         // 中标
  LOST        // 落标
  ABANDONED   // 放弃
}

// 我方对某个真实项目（按 threadKey 归并）的手工投标跟踪
model BidTracking {
  id          Int          @id @default(autoincrement())
  threadKey   String       @unique // 一个真实项目一条跟踪记录（= BidProject.threadKey）
  ourStatus   OurBidStatus @default(WATCHING)
  ourPrice    String? // 我方报价
  competitors String? // 我方了解到的竞争对手（自由文本）
  outcome     String? // 结果/结论备注
  note        String? // 跟进备注
  updatedById Int? // 最后更新人
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([ourStatus])
}

enum ScrapeJobStatus {
  RUNNING
  DONE
  FAILED
}

enum NotificationType {
  STATUS_CHANGE // 关注项目状态变更
  DEADLINE_SOON // 关注项目截止临近
  COMPETITOR_WIN // 竞争对手中标
  OWN_WIN // 本集团中标
  INTEREST_WIN // 关注公司中标
  NEW_RELEVANT // 新相关项目
}

enum WatchType {
  OWN // 本集团（Herkules / Waldrich Siegen）
  COMPETITOR // 竞争对手
  INTEREST // 关注公司（感兴趣但非直接竞品）
}

enum CustomerStatus {
  LEAD // 潜在客户
  ACTIVE // 合作中
  INACTIVE // 暂停 / 沉睡
  LOST // 已流失
}

enum CustomerTier {
  A // 战略客户
  B // 重点客户
  C // 普通客户
}
